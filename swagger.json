{
  "swagger": "2.0",
  "info": {
    "title": "Library API",
    "description": "REST API for managing a library — books and authors collections. Protected routes require GitHub OAuth login at /auth/github.",
    "version": "1.0.0"
  },
  "host": "cse341-librarymanager.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "securityDefinitions": {
    "githubOAuth": {
      "type": "oauth2",
      "authorizationUrl": "https://cse341-librarymanager.onrender.com/auth/github",
      "flow": "implicit",
      "scopes": {
        "user:email": "Read user email from GitHub"
      }
    }
  },
  "paths": {

    "/auth/github": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Login with GitHub OAuth",
        "description": "Redirects the user to GitHub to authenticate. After approval, GitHub redirects to /auth/github/callback.",
        "responses": {
          "302": { "description": "Redirect to GitHub" }
        }
      }
    },
    "/auth/github/callback": {
      "get": {
        "tags": ["Authentication"],
        "summary": "GitHub OAuth callback",
        "description": "GitHub redirects here after authentication. On success, redirects to /auth/profile.",
        "responses": {
          "302": { "description": "Redirect to /auth/profile on success" },
          "401": { "description": "Authentication failed" }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get logged-in user profile",
        "description": "Returns the currently authenticated user's GitHub profile.",
        "responses": {
          "200": { "description": "User profile returned" },
          "401": { "description": "Not authenticated" }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Logout",
        "description": "Destroys the session and logs the user out.",
        "responses": {
          "200": { "description": "Logged out successfully" }
        }
      }
    },

    "/books": {
      "get": {
        "tags": ["Books"],
        "summary": "Get all books (public)",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "A list of books" },
          "500": { "description": "Internal server error" }
        }
      },
      "post": {
        "tags": ["Books"],
        "summary": "Create a new book (protected)",
        "description": "Requires GitHub OAuth login. Visit /auth/github first.",
        "security": [{ "githubOAuth": ["user:email"] }],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["title","isbn","authorId","genre","publishedYear","pageCount","language","publisher","summary"],
              "properties": {
                "title":         { "type": "string",  "example": "1984" },
                "isbn":          { "type": "string",  "example": "978-0-451-52493-5" },
                "authorId":      { "type": "string",  "example": "664f1a2b3c4d5e6f7a8b9c0d" },
                "genre":         { "type": "string",  "example": "Dystopian" },
                "publishedYear": { "type": "integer", "example": 1949 },
                "pageCount":     { "type": "integer", "example": 328 },
                "language":      { "type": "string",  "example": "English" },
                "publisher":     { "type": "string",  "example": "Secker & Warburg" },
                "summary":       { "type": "string",  "example": "A chilling portrait of a totalitarian society." },
                "available":     { "type": "boolean", "example": true }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Book created successfully" },
          "400": { "description": "Validation error or duplicate ISBN" },
          "401": { "description": "Unauthorized — login required" }
        }
      }
    },

    "/books/{id}": {
      "get": {
        "tags": ["Books"],
        "summary": "Get a single book by ID (public)",
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book found" },
          "404": { "description": "Book not found" },
          "500": { "description": "Internal server error" }
        }
      },
      "put": {
        "tags": ["Books"],
        "summary": "Update a book by ID (protected)",
        "description": "Requires GitHub OAuth login. Visit /auth/github first.",
        "security": [{ "githubOAuth": ["user:email"] }],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title":         { "type": "string" },
                "isbn":          { "type": "string" },
                "authorId":      { "type": "string" },
                "genre":         { "type": "string" },
                "publishedYear": { "type": "integer" },
                "pageCount":     { "type": "integer" },
                "language":      { "type": "string" },
                "publisher":     { "type": "string" },
                "summary":       { "type": "string" },
                "available":     { "type": "boolean" }
              }
            }
          }
        ],
        "responses": {
          "204": { "description": "Book updated successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Book not found" }
        }
      },
      "delete": {
        "tags": ["Books"],
        "summary": "Delete a book by ID (protected)",
        "description": "Requires GitHub OAuth login. Visit /auth/github first.",
        "security": [{ "githubOAuth": ["user:email"] }],
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book deleted successfully" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Book not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },

    "/authors": {
      "get": {
        "tags": ["Authors"],
        "summary": "Get all authors (public)",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "A list of authors" },
          "500": { "description": "Internal server error" }
        }
      },
      "post": {
        "tags": ["Authors"],
        "summary": "Create a new author (protected)",
        "description": "Requires GitHub OAuth login. Visit /auth/github first.",
        "security": [{ "githubOAuth": ["user:email"] }],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["firstName","lastName","email","nationality","birthDate","biography","genres"],
              "properties": {
                "firstName":   { "type": "string",  "example": "George" },
                "lastName":    { "type": "string",  "example": "Orwell" },
                "email":       { "type": "string",  "example": "gorwell@example.com" },
                "nationality": { "type": "string",  "example": "British" },
                "birthDate":   { "type": "string",  "example": "1903-06-25" },
                "biography":   { "type": "string",  "example": "English novelist known for 1984 and Animal Farm." },
                "website":     { "type": "string",  "example": "https://georgeorwell.org" },
                "genres":      { "type": "array", "items": { "type": "string" }, "example": ["Dystopian","Political Fiction"] },
                "active":      { "type": "boolean", "example": true }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Author created successfully" },
          "400": { "description": "Validation error or duplicate email" },
          "401": { "description": "Unauthorized — login required" }
        }
      }
    },

    "/authors/{id}": {
      "get": {
        "tags": ["Authors"],
        "summary": "Get a single author by ID (public)",
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Author found" },
          "404": { "description": "Author not found" },
          "500": { "description": "Internal server error" }
        }
      },
      "put": {
        "tags": ["Authors"],
        "summary": "Update an author by ID (protected)",
        "description": "Requires GitHub OAuth login. Visit /auth/github first.",
        "security": [{ "githubOAuth": ["user:email"] }],
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "firstName":   { "type": "string" },
                "lastName":    { "type": "string" },
                "email":       { "type": "string" },
                "nationality": { "type": "string" },
                "birthDate":   { "type": "string" },
                "biography":   { "type": "string" },
                "website":     { "type": "string" },
                "genres":      { "type": "array", "items": { "type": "string" } },
                "active":      { "type": "boolean" }
              }
            }
          }
        ],
        "responses": {
          "204": { "description": "Author updated successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Author not found" }
        }
      },
      "delete": {
        "tags": ["Authors"],
        "summary": "Delete an author by ID (protected)",
        "description": "Requires GitHub OAuth login. Visit /auth/github first.",
        "security": [{ "githubOAuth": ["user:email"] }],
        "produces": ["application/json"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Author deleted successfully" },
          "401": { "description": "Unauthorized — login required" },
          "404": { "description": "Author not found" },
          "500": { "description": "Internal server error" }
        }
      }
    }

  }
}